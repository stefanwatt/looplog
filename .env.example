PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Cloudflare Pages: set the same PUBLIC_* vars in the dashboard
# (Settings → Environment variables) for Production and Preview.

# Google OAuth (Supabase Dashboard → Authentication → Providers → Google):
# 1. Create a Google Cloud OAuth client (Web application).
# 2. Authorized JavaScript origins: http://localhost:5173 and your production URL.
# 3. Authorized redirect URI: copy from the Google provider page in Supabase
#    (https://<project-ref>.supabase.co/auth/v1/callback).
# 4. Paste Client ID and Client Secret into Supabase.
# 5. Authentication → URL Configuration → Redirect URLs: add
#    http://localhost:5173/auth/callback and https://<your-domain>/auth/callback.

# Optional: used by Supabase CLI / direct DB access
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=
